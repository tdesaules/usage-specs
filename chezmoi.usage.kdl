name "chezmoi"
bin "chezmoi"
about "Manage your dotfiles across multiple diverse machines, securely."
version "2.70.0"
flag "-c --config <FILE>" help="The configuration file"
flag "-D --destination <DIR>" help="The destination directory"
flag "-S --source <DIR>" help="The source directory"
flag "-n --dry-run" help="Do not make any changes"
flag "-v --verbose" help="Print more information"
flag "--cache <DIR>" help="The cache directory"
flag "--color <WHEN>" help="Colorize output" {
    choices "always" "auto" "never"
}
flag "--config-format <FORMAT>" help="The configuration file format" {
    choices "json" "jsonc" "toml" "yaml"
}
flag "--force" help="Make changes without prompting"
flag "-k --keep-going" help="Keep going after errors"
flag "--no-pager" help="Do not use a pager"
flag "--no-tty" help="Do not use a TTY"
flag "-o --output <FILE>" help="Write output to <FILE> instead of stdout"
flag "--progress <WHEN>" help="Show progress" {
    choices "always" "auto" "never"
}
flag "-R --refresh-externals <WHEN>" help="Refresh external resources" {
    choices "always" "auto" "never"
}
flag "--use-builtin-age <BOOL>" help="Use builtin age"
flag "--use-builtin-git <BOOL>" help="Use builtin git"
flag "--cpu-profile <FILE>" help="Write a CPU profile to <FILE>"
flag "--mem-profile <FILE>" help="Write a memory profile to <FILE>"
flag "--trace <FILE>" help="Write a trace to <FILE>"
cmd "add" help="Add files to the source state" {
    alias "manage"
    flag "-f --follow" help="Follow symlinks"
    flag "-p --prompt" help="Prompt for each file"
    flag "-r --recursive" help="Add directories recursively"
    flag "-T --template" help="Add files as templates"
    flag "--encrypt" help="Encrypt files"
    flag "--exact" help="Add directories exactly"
    arg "<paths>..." help="Files or directories to add"
}
cmd "age" help="Interact with age" {
    cmd "decrypt" { arg "<file>" }
    cmd "encrypt" { arg "<file>" }
    cmd "keygen" help="Generate a new age key pair"
}
cmd "age-keygen" help="Generate a new age key pair"
cmd "apply" help="Update the destination directory to match the target state" {
    flag "--init" help="Recreate the config file from the template"
    arg "<paths>..." help="Files or directories to apply" optional=true
}
cmd "archive" help="Write an archive of the target state to stdout" {
    flag "--format <FORMAT>" help="Archive format" {
        choices "tar" "tar.gz" "tar.bz2" "tar.xz" "zip"
    }
}
cmd "cat" help="Print the target contents of a file" {
    arg "<path>" help="File to print"
}
cmd "cat-config" help="Print the configuration file"
cmd "cd" help="Launch a shell in the source directory"
cmd "chattr" help="Change the attributes of a file in the source state" {
    arg "<attributes>" help="Attributes (e.g. [+|-][template,encrypted,private,etc])"
    arg "<paths>..." help="Files to change"
}
cmd "completion" help="Generate shell completion scripts" {
    arg "<shell>" help="The shell to generate for" {
        choices "bash" "fish" "powershell" "zsh"
    }
}
cmd "data" help="Print the available template data" {
    flag "--format <FORMAT>" help="Output format" {
        choices "json" "yaml"
    }
}
cmd "decrypt" help="Decrypt a file" {
    arg "<path>" help="File to decrypt"
}
cmd "destroy" help="Purge chezmoi's configuration, source directory, and state" {
    flag "--force" help="Destroy without prompting"
}
cmd "diff" help="Show differences between target and destination state" {
    flag "--reverse" help="Show differences in reverse"
    arg "<paths>..." help="Files or directories to diff" optional=true
}
cmd "docker" help="Run chezmoi inside a Docker container" {
    cmd "run" { arg "<image>"; arg "<args>..." optional=true }
    cmd "exec" { arg "<container>"; arg "<args>..." optional=true }
}
cmd "doctor" help="Check your system for potential problems"
cmd "dump" help="Write the target state to stdout" {
    flag "-i --include <TYPES>" help="Include only specified entry types"
    flag "-x --exclude <TYPES>" help="Exclude specified entry types"
    flag "--format <FORMAT>" help="Output format" { choices "json" "yaml"; }
}
cmd "dump-config" help="Write the configuration to stdout"
cmd "edit" help="Edit the source state of files" {
    flag "--apply" help="Apply changes after editing"
    flag "--diff" help="Show differences after editing"
    arg "<paths>..." help="Files to edit"
}
cmd "edit-config" help="Edit the configuration file"
cmd "edit-config-template" help="Edit the configuration file template"
cmd "edit-encrypted" help="Edit an encrypted file" {
    arg "<paths>..." help="Files to edit"
}
cmd "encrypt" help="Encrypt a file" {
    arg "<path>" help="File to encrypt"
}
cmd "execute-template" help="Execute one or more templates" {
    flag "-p --prompt" help="Prompt for template data"
    arg "<templates>..." help="Template strings or files" optional=true
}
cmd "forget" help="Remove files from the source state without removing them from destination" {
    alias "unmanage"
    arg "<paths>..." help="Files to forget"
}
cmd "generate" help="Generate a file" {
    arg "<path>" help="Path to generate"
}
cmd "git" help="Run git in the source directory" {
    arg "<args>..." help="Arguments for git"
}
cmd "help" help="Help about any command" {
    arg "<command>" help="Command to get help for" optional=true
}
cmd "ignored" help="List ignored files" {
    flag "--tree" help="List ignored files as a tree"
}
cmd "import" help="Import the source state from an archive" {
    arg "<archive>" help="Archive to import"
}
cmd "init" help="Setup the source directory and optionally clone a repository" {
    flag "--apply" help="Apply changes after initialization"
    flag "--data" help="Prompt for template data"
    flag "--ssh" help="Use SSH to clone the repository"
    flag "--branch <BRANCH>" help="Branch to checkout"
    arg "<repo>" help="URL or GitHub username/repo" optional=true
}
cmd "license" help="Print the license"
cmd "managed" help="List managed files" {
    alias "list"
    alias "ls"
    flag "-i --include <TYPES>" help="Include only specified entry types"
    flag "-x --exclude <TYPES>" help="Exclude specified entry types"
}
cmd "merge" help="Merge changes from the source state into the destination" {
    arg "<paths>..." help="Files to merge"
}
cmd "merge-all" help="Merge all changes from the source state into the destination"
cmd "podman" help="Run chezmoi inside a Podman container"
cmd "purge" help="Purge chezmoi's configuration and source directory"
cmd "re-add" help="Re-add files to the source state" {
    arg "<paths>..." help="Files or directories to re-add" optional=true
}
cmd "remove" help="Remove files from the source state and the destination" {
    alias "rm"
    arg "<paths>..." help="Files to remove"
}
cmd "secret" help="Interact with a secret manager" {
    cmd "keyring" {
        cmd "get" { flag "--service <S>"; flag "--user <U>" }
        cmd "set" { flag "--service <S>"; flag "--user <U>"; flag "--value <V>" }
        cmd "delete" { flag "--service <S>"; flag "--user <U>" }
    }
}
cmd "source-path" help="Print the source path of a file" {
    arg "<paths>..." help="Files to get paths for" optional=true
}
cmd "ssh" help="Run ssh in the source directory" {
    arg "<args>..." help="Arguments for ssh"
}
cmd "state" help="Interact with the state database" {
    cmd "data"
    cmd "delete" { arg "<key>" }
    cmd "dump"
    cmd "get" { arg "<key>" }
    cmd "reset"
    cmd "set" { arg "<key>"; arg "<value>" }
}
cmd "status" help="Show the status of managed files" {
    arg "<paths>..." help="Files to check" optional=true
}
cmd "target-path" help="Print the target path of a file" {
    arg "<paths>..." help="Files to get paths for" optional=true
}
cmd "update" help="Pull changes from the source repository and apply them" {
    flag "--apply" help="Apply changes after updating"
}
cmd "upgrade" help="Upgrade chezmoi to the latest version"
cmd "verify" help="Verify that the destination state matches the target state" {
    arg "<paths>..." help="Files or directories to verify" optional=true
}
